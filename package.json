<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1">
<title>Submit receipt</title>
<link rel="stylesheet" href="/upload.css">
</head>
<body>

<!-- ============ LOADING STATE ============ -->
<div class="card hidden" id="loadingCard">
  <div class="content" style="text-align:center;padding:80px 24px;">
    <div style="font-size:32px;margin-bottom:16px;">⏳</div>
    <div style="font-size:14px;color:#aaa;">Loading receipt details…</div>
  </div>
</div>

<!-- ============ NOT FOUND / EXPIRED ============ -->
<div class="card hidden" id="notFoundCard">
  <div class="content" style="text-align:center;padding:60px 24px;">
    <div style="font-size:40px;margin-bottom:16px;">🔗</div>
    <div style="font-size:16px;color:#fff;margin-bottom:8px;">Link expired or not found</div>
    <div style="font-size:13px;color:#888;">If you think this is a mistake, please reach out to accounts payable.</div>
  </div>
</div>

<!-- ============ RESOLVED (already submitted) ============ -->
<div class="card hidden" id="resolvedCard">
  <div class="rsvd-check">✓</div>
  <h1 class="rsvd-title">Receipt already submitted</h1>
  <div class="rsvd-sub" id="resolvedWhen"></div>
  <div class="rsvd-meta">
    <div class="rsvd-row"><span>Vendor</span><span id="resolvedVendor"></span></div>
    <div class="rsvd-row"><span>Amount</span><span id="resolvedAmount"></span></div>
    <div class="rsvd-row"><span>Charge date</span><span id="resolvedDate"></span></div>
  </div>
  <a class="rsvd-btn rsvd-btn-secondary" id="resolvedReplace" href="#">Upload a replacement</a>
  <div class="rsvd-footer">iicorp.org</div>
</div>

<!-- ============ MAIN FORM ============ -->
<div class="card hidden" id="cardWrap">

  <!-- ============ NORMAL MODE ============ -->
  <div id="normalMode">

    <header class="head">
      <span class="head-icon">💳</span>
      <div>
        <div class="head-title">Receipt for your Citi charge</div>
        <div class="head-sub">iicorp.org · Hi <span id="userName">Cardholder</span></div>
      </div>
    </header>

    <div class="content">

      <div class="txn-box">
        <div class="txn-label">Transaction</div>
        <div class="txn-amount" id="txnAmount">$0.00</div>
        <div class="txn-vendor"><span id="txnVendor">—</span> · <span id="txnDate">—</span></div>
        <div class="txn-meta">Card ending <span id="txnCard">----</span></div>
      </div>

      <div class="existing-box hidden" id="existingBox">
        <div class="existing-label"><span id="existingCount">0</span> receipt(s) already on file · adding more</div>
      </div>

      <form id="form">

        <div class="field">
          <label>Which store(s) was this for? <span class="req-tag" data-req-for="store"></span></label>
          <input type="text" name="store" id="storeInput" placeholder="e.g. Store 0640, HQ">
          <div class="hint">Helps accounting bill the right site</div>
        </div>

        <div class="field">
          <label>Description <span class="req-tag" data-req-for="description"></span></label>
          <textarea name="description" id="descInput" placeholder="What was this for?"></textarea>
        </div>

        <div class="field">
          <label>Receipt photo(s) <span class="req-tag" data-req-for="photo"></span></label>
          <div class="photo-grid">
            <label class="photo-btn">
              <input type="file" id="cameraInput" accept="image/*" capture="environment" multiple hidden>
              <span class="photo-icon">📷</span>
              <span>Take photo</span>
            </label>
            <label class="photo-btn">
              <input type="file" id="uploadInput" accept="image/*,application/pdf,.heic" multiple hidden>
              <span class="photo-icon">⬆️</span>
              <span>Choose file(s)</span>
            </label>
          </div>
          <div class="hint center">JPG, PNG, HEIC or PDF · add as many as you need</div>
          <div class="thumb-row" id="thumbRow"></div>
        </div>

        <button type="submit" id="submitBtn" class="submit">Submit receipt</button>

        <div class="fraud-link" id="fraudLinkBox">
          <div class="fraud-link-title">🚨 I didn't make this charge</div>
          <div class="fraud-link-sub">Report as fraud →</div>
        </div>

        <div class="footnote">Edit anytime — just tap the same link again</div>

      </form>

      <div class="done hidden" id="done">
        <div class="done-icon">✅</div>
        <div class="done-title">Thanks!</div>
        <div class="done-sub">Your receipt(s) were submitted. You can close this page,
          or tap below to add more or edit.</div>
        <button class="submit secondary" id="editAgain">Add or edit</button>
      </div>
    </div>
  </div>

  <!-- ============ FRAUD MODE ============ -->
  <div id="fraudMode" class="hidden">

    <header class="head fraud-head">
      <span class="head-icon">🛡️</span>
      <div>
        <div class="head-title">Reporting fraudulent charge</div>
        <div class="head-sub">iicorp.org · Hi <span id="userNameFraud">Cardholder</span></div>
      </div>
    </header>

    <div class="content">

      <div class="fraud-banner">
        <div class="fraud-banner-title">⚠ Unauthorized charge</div>
        <div class="fraud-banner-body">Admins will be notified immediately.</div>
      </div>

      <div class="txn-box">
        <div class="txn-label">Transaction</div>
        <div class="txn-amount" id="txnAmountFraud">$0.00</div>
        <div class="txn-vendor"><span id="txnVendorFraud">—</span> · <span id="txnDateFraud">—</span></div>
        <div class="txn-meta">Card ending <span id="txnCardFraud">----</span></div>
      </div>

      <div class="field">
        <label>Optional note for admins</label>
        <textarea id="fraudNote" placeholder="Anything they should know?"></textarea>
      </div>

      <button id="fraudSubmit" class="submit fraud-submit">Report fraudulent charge</button>
      <button id="backToNormal" class="submit secondary">Back</button>

      <div class="done hidden" id="fraudDone">
        <div class="done-icon">📨</div>
        <div class="done-title">Admins notified</div>
        <div class="done-sub">Thanks for flagging this. We'll be in touch.</div>
      </div>
    </div>
  </div>

</div>

<script src="/upload.js"></script>
</body>
</html>
